# Application
NODE_ENV=development
PORT=3000
API_URL=https://api.korarender.com

# Database
DATABASE_URL=postgresql://kora_user:kora_password@localhost:5432/kora_render

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=30d

# Admin
ADMIN_API_KEY=your-admin-api-key-change-in-production

# Hotmart
HOTMART_WEBHOOK_SECRET=your-hotmart-webhook-secret
HOTMART_TOKEN=your-hotmart-token

# Rate Limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Redis (optional)
REDIS_URL=redis://localhost:6379
